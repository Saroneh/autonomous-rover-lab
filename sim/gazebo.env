# Module 2 — Gazebo Harmonic paths (edit if you cloned elsewhere)
GZ_VERSION=harmonic

# Official ArduPilot Gazebo plugin (build required — see docs/module-2-gazebo.md)
ARDUPILOT_GAZEBO_DIR="${HOME}/ardupilot_gazebo"

# Rover worlds + models (optional but recommended)
SITL_MODELS_DIR="${HOME}/SITL_Models"

# World file name (resolved via GZ_SIM_RESOURCE_PATH) or absolute path
# Options with vehicle included: r1_rover_runway.sdf
# Playpen (obstacles, download models on first run): rover_playpen.sdf
GAZEBO_WORLD=r1_rover_runway.sdf
